#!/usr/bin/env bash

usage() {
  cat <<EOF
Usage: $0 [ -b branch_name ] path_to_client_project_di

Deploys bento application from its build directory to the Web site

Options:

    -b branch-name            Perform a fresh build from git branch
    -h                        Print this help and exit (opt)

Example: $0 /Users/florinb/projects/bcbento_client

EOF
  exit
}

# Something bad has happened. Exit.
exit_abnormal() {
  usage
  exit 1
}

# Setup text color codes
setup_colors() {
  if [[ -t 2 ]] && [[ "${TERM-}" != "dumb" ]]; then
    NOFORMAT='\033[0m' RED='\033[0;31m' GREEN='\033[0;32m' ORANGE='\033[0;33m' BLUE='\033[0;34m' PURPLE='\033[0;35m' CYAN='\033[0;36m' YELLOW='\033[1;33m'
  else
    NOFORMAT='' RED='' GREEN='' ORANGE='' BLUE='' PURPLE='' CYAN='' YELLOW=''
  fi
}

# Print a message to the screen, possibly with color
msg() {
  echo >&2 -e "${1-}"
}

# Print an error and exit
error_out() {
  msg "${RED}Error: ${1-}${NOFORMAT}"
  exit_abnormal
}

# Make sure all the paths in the Hugo theme exist
function validate_theme_files() {
  msg "${YELLOW}Validating theme directories${NOFORMAT}"

  # Die if theme directories and files aren't where they are supposed to be.
  if [ ! -d "$bento_theme_dir" ]; then
    error_out "...bento directory not found in theme ${bento_theme_dir}"
  fi

  if [ ! -d "$static_theme_dir" ]; then
    error_out "...bento static directory not found in theme ${static_theme_dir}"
  fi

  if [ ! -f "$search_layout" ]; then
    error_out "...search layout not found in theme ${search_layout}"
  fi
}

# Build a new deployment of the client.
function build_client() {
  msg "${YELLOW}Building client${NOFORMAT}"

  pushd "$path_to_client" || error_out "...could not cd to client at $path_to_client"
  
  current_branch=$(git rev-parse --abbrev-ref HEAD)
  git checkout "$branch" || error_out "...couldn't checkout client branch $branch"
  yarn build || error_out "...couldn't build client"
  git checkout "$current_branch"
  popd || return
}

# Remove any old files.
function clean_old_files() {
  msg "${YELLOW}Cleaning old files${NOFORMAT}"

  msg "...removing old js dir"
  rm -r "${js_theme_dir}" || error_out "...couldn't delete JS directory $js_theme_dir"

  msg "...removing stran javascript and JSON"
  for f in "${bento_theme_dir}"/*js*; do
    if [ -f "$f" ]; then
      rm "$f" || error_out "...couldn't delete ${f}"
    fi
  done
}

# Copy in the fresh files.
function copy_build_files() {
  msg "${YELLOW}Copying build files${NOFORMAT}"
  
  msg "...copying over new js directory"
  cp -r "${path_to_client}"/build/static/js "${static_theme_dir}" || error_out "...couldn't copy js directory"
  
  msg "...copying over new media directory"
  cp -r "${path_to_client}"/build/static/media "${static_theme_dir}" || error_out "...couldn't copy media directory"

  msg "...copying over new stray javascript and json"
  cp "${path_to_client}"/build/*js* "${bento_theme_dir}" || error_out "...couldn't copy stray js"
}

# Update the Hugo search layout document to reflect the new javascript files.
function update_search_layout() {

  msg "${YELLOW}Updating search layout${NOFORMAT}"

  build_index_path=${path_to_client}/build/index.html
  if [ ! -f "$build_index_path" ]; then
    error_out "...build index.html not found in ${build_index_path}"
  fi

  # Each new version of the application javascript has a unique fingerprint
  # in the filename (e.g. main.1f0329df.js). Find that file in the built 
  # index.html file and use it to fill in the value in the search page 
  # layout.
  build_index=$(cat "${build_index_path}")
  pattern='\/main.([^/]*).js'

  [[ "$build_index" =~ $pattern ]]
  main_fingerprint=${BASH_REMATCH[1]}
  if [ -z "$main_fingerprint" ]; then
   error_out "...could not find main javascript fingerprint in index.html"
  fi

  msg "...replacing old js fingerprint with ${main_fingerprint}"
  sed -i '' -e "s/main\.[^/]*\.js/main.$main_fingerprint.js/" "$search_layout"
}

# Directories in theme.
theme_dir=$(dirname "$0")/../themes/BC
bento_theme_dir=${theme_dir}/static/bcbento
static_theme_dir=${bento_theme_dir}/static
js_theme_dir=${static_theme_dir}/js
media_theme_dir=${static_theme_dir}/media

# The Hugo layout file for the search page.
search_layout=${theme_dir}/layouts/search/search.html.html

#Options
build=false
branch="master"

# Arguments
path_to_client=

setup_colors

#  Start the program
validate_theme_files

while getopts ":hb:" opt; do
  case ${opt} in
  h)
    usage
    exit 0
    ;;
  b)
    build=true
    branch=$OPTARG
    ;;
  \?)
    error_out "Invalid Option: -$OPTARG" 1>&2
    ;;
  esac
  shift $((OPTIND - 1))
done

path_to_client=$1
if [ ! -d "$path_to_client" ]; then
  error_out "Could not find bento client dir ${path_to_client}"
fi

if [ "$build" = true ]; then
  build_client
fi

clean_old_files
copy_build_files
update_search_layout